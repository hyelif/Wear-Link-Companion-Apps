<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <!-- CFBundleExecutable MUST be present and resolve to the actual binary
         filename (WearLink). Without it, SideStore/ldid's
         -[ALTApplication entitlements] -> ldid::ExecutablePath -> plist_s
         reads a NULL node, and plist_s does `return NULL` into a std::string,
         which throws std::logic_error -> uncaught -> SIGABRT during install.
         Xcode normally injects this key, but only when GENERATE_INFOPLIST_FILE=YES;
         this target uses a custom INFOPLIST_FILE, so it must be supplied here. -->
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleName</key>
    <string>WearLink</string>
    <key>CFBundleDisplayName</key>
    <string>WearLink</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIDeviceFamily</key>
    <array>
        <integer>1</integer>
    </array>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <key>UIRequiresFullScreen</key>
    <true/>
    <!-- Launch screen storyboard — required for fullscreen on sideloaded/unsigned
         IPA builds (SideStore). UILaunchScreen with UIColorName alone does not
         trigger fullscreen sizing on iOS 26 when sideloaded without a provisioning
         profile. A physical .storyboard file forces iOS to respect the app's
         TARGETED_DEVICE_FAMILY and render at full UIScreen bounds. -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIBackgroundModes</key>
    <array>
        <!-- Bridge model: iPhone is the GATT server (CBPeripheralManager).
             bluetooth-peripheral keeps the peripheral manager / advertiser
             alive in background so the watch can reconnect while the iPhone
             screen is off. bluetooth-central retained for compatibility with
             any residual central-mode code paths.
             remote-notification REMOVED: APNs requires a paid Apple Developer
             Program (not available on free / SideStore accounts). Re-add for a
             paid / App Store build once the NotificationServiceExtension is restored. -->
        <string>bluetooth-peripheral</string>
        <string>bluetooth-central</string>
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <!-- Bluetooth: required for BLE communication with the watch.
         NSBluetoothAlwaysUsageDescription is the REQUIRED key on iOS 13+ for
         CBCentralManager to access Bluetooth AND to trigger the system Bluetooth
         permission prompt. Without it, the prompt never appears and CBCentralManager
         stays .unauthorized (or crashes on first access). NSBluetoothPeripheralUsage
         Description is the deprecated pre-iOS-13 CBPeripheralManager key, kept for
         backward compatibility. -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>WearLink connects to your Wear OS watch over Bluetooth to sync health, calls, notifications, and music.</string>
    <key>NSBluetoothPeripheralUsageDescription</key>
    <string>WearLink connects to your Wear OS watch over Bluetooth to sync health, calls, notifications, and music.</string>
    <!-- Contacts: caller name lookup for call handling -->
    <key>NSContactsUsageDescription</key>
    <string>WearLink looks up caller names to show them on your watch.</string>
</dict>
</plist>