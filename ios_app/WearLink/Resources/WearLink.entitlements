<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- HealthKit read+write of data received from watch -->
	<key>com.apple.developer.healthkit</key>
	<true/>
	<key>com.apple.developer.healthkit.access</key>
	<array/>
	<!-- Background BLE central is granted via UIBackgroundModes, no entitlement needed.
	     aps-environment + app-group REMOVED for SideStore (free-account) unsigned builds:
	     APNs (aps-environment) requires a PAID Apple Developer Program; the
	     NotificationServiceExtension target is also excluded from this build (it
	     needs APNs + a separate App ID that SideStore cannot provision on a free
	     account — its presence makes SideStore crash / refuse to install). Re-add
	     aps-environment + app-group + the NotificationServiceExtension target for a
	     paid / App Store build. -->
</dict>
</plist>
