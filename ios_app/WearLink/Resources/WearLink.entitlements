<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- SideStore (free-account) launch build: NO entitlements, matching the
	     working unsigned Flutter build exactly.

	     NOTE: under the CI unsigned archive (CODE_SIGNING_ALLOWED=NO) this file
	     is a build-time signing input only and is NOT shipped in the .app, so it
	     has no runtime effect on the SideStore-resigned IPA. It is kept empty
	     for hygiene + so a future PAID / App Store signed build can re-add:
	       - com.apple.developer.healthkit            (Apple Health write)
	       - com.apple.developer.healthkit.access      (clinical types array)
	       - com.apple.security.application-groups    (NSE bridge)
	       - aps-environment = production            (push, with NSE target)
	     HealthKit code paths stay in the app and are guarded (do-catch around
	     requestAuthorization), so they no-op safely without the entitlement. -->
</dict>
</plist>