# CocoaPods — WearLink iOS app
# Install: cd ios_app && pod install
# Open WearLink.xcworkspace (generated by XcodeGen + CocoaPods)
#
# NOTE: All pods removed — protobuf serialization uses hand-written
# ProtoCodec, not SwiftProtobuf. Empty targets removed to prevent
# pod install from creating Pods_* framework references that the
# linker would try (and fail) to resolve.

platform :ios, '17.0'
use_frameworks!